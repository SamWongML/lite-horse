# Copy this file to .env at repo root for local cloud-stack dev,
# or to ~/.litehorse/.env (or set LITEHORSE_HOME) for the v0.3 CLI.

# === LLM provider keys (used by the agent runtime) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === OpenAI-compatible passthrough (Azure OpenAI, LiteLLM, vLLM, Ollama, …) ===
# Route to any OpenAI-API-shaped server (including LiteLLM's Responses-
# compatible surface) by setting the model to ``oai/<upstream-name>``.
# The ``oai/`` prefix is stripped before the request leaves; the upstream
# sees its own native model identifier (Azure deployment id, LiteLLM
# registered name, etc.). Add a pricing row in
# src/lite_horse/data/pricing.yaml under the stripped name to track cost.
#
# Examples:
#   model: oai/azure-gpt-4o-mini   → POST <BASE_URL>/chat/completions {"model":"azure-gpt-4o-mini",...}
#   model: oai/llama-3.1-70b       → routed through your LiteLLM proxy
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=

# === v0.4 cloud-stack settings (LITEHORSE_ env-prefix, read by Settings) ===
LITEHORSE_ENV=local
LITEHORSE_DATABASE_URL=postgresql+asyncpg://litehorse:litehorse@localhost:5432/litehorse
LITEHORSE_REDIS_URL=redis://localhost:6379/0

# S3 / MinIO
LITEHORSE_S3_ENDPOINT=http://localhost:9000
LITEHORSE_S3_ACCESS_KEY=minioadmin
LITEHORSE_S3_SECRET_KEY=minioadmin
LITEHORSE_S3_BUCKET_ATTACHMENTS=litehorse-local-attachments
LITEHORSE_S3_BUCKET_EVOLVE=litehorse-local-evolve
LITEHORSE_S3_BUCKET_EXPORTS=litehorse-local-exports
LITEHORSE_S3_BUCKET_AUDIT=litehorse-local-audit-archive

# Local KMS (Fernet) — base64-urlsafe 32-byte key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LITEHORSE_LOCAL_KMS_KEY=

# JWT verification (webapp issues JWTs verifiable via JWKS)
LITEHORSE_JWT_JWKS_URL=http://localhost:9999/.well-known/jwks.json
LITEHORSE_JWT_ISSUER=http://localhost:9999
LITEHORSE_JWT_AUDIENCE=lite-horse
